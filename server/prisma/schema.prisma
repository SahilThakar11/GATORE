generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  role          String         @default("user")
  emailVerified Boolean        @default(false)
  isActive      Boolean        @default(false)
  password      String
  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  reservations  Reservation[]
  staffActions  StaffAction[]
  googleId      String?        @unique
  authProvider  String         @default("email")
  @@map("users")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  code      String
  userId    Int      @map("user_id")
  type      String
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Restaurant {
  id             Int              @id @default(autoincrement())
  name           String
  address        String
  website        String
  games          Game[]
  operatingHours OperatingHours[]
  tables         Table[]

  @@map("restaurant")
}

model Table {
  id           Int           @id @default(autoincrement())
  name         String
  capacity     Int
  status       String
  restaurantId Int
  reservations Reservation[]
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])

  @@map("table")
}

model Game {
  id                Int               @id @default(autoincrement())
  name              String
  minPlayers        Int               @map("min_players")
  maxPlayers        Int               @map("max_players")
  estimatedPlayTime Int               @map("estimated_play_time")
  status            String
  restaurantId      Int
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])
  gameIssues        GameIssue[]
  gameReservations  GameReservation[]

  @@map("game")
}

model Reservation {
  id               Int               @id @default(autoincrement())
  reservationDate  DateTime          @map("reservation_date")
  startTime        DateTime          @map("start_time")
  endTime          DateTime          @map("end_time")
  partySize        Int               @map("party_size")
  status           String
  userId           Int
  tableId          Int
  gameReservations GameReservation[]
  table            Table             @relation(fields: [tableId], references: [id])
  user             User              @relation(fields: [userId], references: [id])

  @@map("reservation")
}

model GameReservation {
  id            Int         @id @default(autoincrement())
  reservationId Int
  gameId        Int
  game          Game        @relation(fields: [gameId], references: [id])
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@map("game_reservation")
}

model GameIssue {
  id           Int           @id @default(autoincrement())
  reportedBy   String        @map("reported_by")
  issueType    String        @map("issue_type")
  notes        String
  reportedAt   DateTime      @default(now()) @map("reported_at")
  resolved     Boolean       @default(false)
  gameId       Int
  game         Game          @relation(fields: [gameId], references: [id])
  staffActions StaffAction[]

  @@map("game_issue")
}

model StaffAction {
  id          Int       @id @default(autoincrement())
  actionType  String    @map("action_type")
  timestamp   Int
  userId      Int
  gameIssueId Int
  gameIssue   GameIssue @relation(fields: [gameIssueId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("staff_action")
}

model OperatingHours {
  id           Int        @id @default(autoincrement())
  dayOfWeek    String     @map("day_of_week")
  openTime     Int
  closeTime    Int
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@map("operating_hours")
}
