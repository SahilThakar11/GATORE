generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at")
  role          String         @default("user")
  emailVerified Boolean        @default(false)
  isActive      Boolean        @default(false)
  password      String
  authProvider  String         @default("email")
  googleId      String?        @unique
  isGuest       Boolean        @default(false)
  otpCodes      OtpCode[]
  refreshTokens RefreshToken[]
  reservations  Reservation[]
  staffActions  StaffAction[]
  preference    UserPreference?

  @@map("users")
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  code      String
  userId    Int      @map("user_id")
  type      String
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Restaurant {
  id              Int                     @id @default(autoincrement())
  name            String
  tagline         String
  description     String
  address         String
  city            String
  province        String                  @default("ON")
  postalCode      String?                 @map("postal_code")
  phone           String?
  logoUrl         String?                 @map("logo_url")
  rating          Decimal                 @default(0) @db.Decimal(3, 2)
  reviewCount     Int                     @default(0) @map("review_count")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @default(now()) @updatedAt @map("updated_at")
  website         String?
  accessRequests  BusinessAccessRequest[]
  operatingHours  OperatingHours[]
  restaurantGames RestaurantGame[]
  tables          Table[]

  @@map("restaurants")
}

model OperatingHours {
  id           Int        @id @default(autoincrement())
  dayOfWeek    String     @map("day_of_week")
  closeTime    Int        @map("close_time")
  isClosed     Boolean    @default(false) @map("is_closed")
  openTime     Int        @map("open_time")
  restaurantId Int        @map("restaurant_id")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("operating_hours")
}

model Table {
  id           Int           @id @default(autoincrement())
  name         String
  capacity     Int
  minCapacity  Int           @default(1) @map("min_capacity")
  status       String        @default("available")
  description  String?
  restaurantId Int           @map("restaurant_id")
  reservations Reservation[]
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("tables")
}

model Game {
  id                Int               @id @default(autoincrement())
  bggId             String            @unique @map("bgg_id")
  name              String
  minPlayers        Int               @map("min_players")
  maxPlayers        Int               @map("max_players")
  estimatedPlayTime Int               @map("estimated_play_time")
  imageUrl          String?           @map("image_url")
  category          String?
  difficulty        String?
  ageRating         String?           @map("age_rating")
  description       String?
  bggRating         Decimal?          @map("bgg_rating") @db.Decimal(4, 2)
  createdAt         DateTime          @default(now()) @map("created_at")
  gameIssues        GameIssue[]
  gameReservations  GameReservation[]
  restaurantGames   RestaurantGame[]

  @@map("games")
}

model RestaurantGame {
  id           Int        @id @default(autoincrement())
  restaurantId Int        @map("restaurant_id")
  gameId       Int        @map("game_id")
  status       String     @default("available")
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, gameId])
  @@map("restaurant_games")
}

model Reservation {
  id               Int               @id @default(autoincrement())
  reservationDate  DateTime          @map("reservation_date")
  startTime        DateTime          @map("start_time")
  endTime          DateTime          @map("end_time")
  partySize        Int               @map("party_size")
  status           String            @default("pending")
  specialRequests  String?           @map("special_requests")
  notes            String?
  createdAt        DateTime          @default(now()) @map("created_at")
  userId           Int               @map("user_id")
  tableId          Int               @map("table_id")
  gameReservations GameReservation[]
  table            Table             @relation(fields: [tableId], references: [id])
  user             User              @relation(fields: [userId], references: [id])

  @@map("reservations")
}

model GameReservation {
  id            Int         @id @default(autoincrement())
  reservationId Int         @map("reservation_id")
  gameId        Int         @map("game_id")
  game          Game        @relation(fields: [gameId], references: [id])
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@map("game_reservations")
}

model GameIssue {
  id           Int           @id @default(autoincrement())
  reportedBy   String        @map("reported_by")
  issueType    String        @map("issue_type")
  notes        String
  reportedAt   DateTime      @default(now()) @map("reported_at")
  resolved     Boolean       @default(false)
  gameId       Int           @map("game_id")
  game         Game          @relation(fields: [gameId], references: [id])
  staffActions StaffAction[]

  @@map("game_issues")
}

model StaffAction {
  id          Int       @id @default(autoincrement())
  actionType  String    @map("action_type")
  notes       String?
  timestamp   DateTime  @default(now())
  userId      Int       @map("user_id")
  gameIssueId Int       @map("game_issue_id")
  gameIssue   GameIssue @relation(fields: [gameIssueId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@map("staff_actions")
}

model BusinessAccessRequest {
  id           Int         @id @default(autoincrement())
  cafeName     String      @map("cafe_name")
  ownerName    String      @map("owner_name")
  email        String
  phone        String?
  city         String
  message      String?
  status       String      @default("pending")
  reviewedAt   DateTime?   @map("reviewed_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  restaurantId Int?        @map("restaurant_id")
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  @@map("business_access_requests")
}

model UserPreference {
  id         Int    @id @default(autoincrement())
  userId     Int    @unique @map("user_id")
  gameTypes  String @default("") @map("game_types")
  groupSize  String @default("any") @map("group_size")
  complexity String @default("any")
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
